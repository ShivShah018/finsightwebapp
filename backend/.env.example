# Database
FINSIGHT_DB_HOST=localhost
FINSIGHT_DB_PORT=3306
FINSIGHT_DB_USER=root
FINSIGHT_DB_PASSWORD=your_password_here
FINSIGHT_DB_NAME=finsight

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# API
API_HOST=0.0.0.0
API_PORT=8000

# App
FINSIGHT_ENV=development
LOG_LEVEL=INFO
FINSIGHT_API_URL=http://localhost:8000
